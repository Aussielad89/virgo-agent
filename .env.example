# LLM API
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=sk-no-key-required
LLM_TIMEOUT=300
MODEL_PLANNER=qwen2.5-coder:7b
MODEL_GENERATOR=qwen2.5-coder:7b
MODEL_FIXER=qwen2.5-coder:7b

# Multi-model router (per-role provider:model — overrides MODEL_*)
# Each value is <provider>:<model>
# Supported providers: ollama, crush, openai, openrouter, groq
#ROUTER_PLANNER=ollama:qwen2.5-coder:32b
#ROUTER_GENERATOR=crush:opencode-zen/deepseek-v4-flash-free
#ROUTER_FIXER=ollama:qwen2.5-coder:7b

# Webhook
WEBHOOK_URL=http://localhost:8080/webhook
WEBHOOK_RETRIES=3

# Dashboard
DASHBOARD_CONFIG=dashboard.json

# Logging
VIRGO_LOG_LEVEL=INFO
VIRGO_LOG_FILE=
